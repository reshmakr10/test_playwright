{
  "name": "test_playwright",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise-grade hybrid automation framework for UI and API testing.",
  "scripts": {
    "ui:test": "npx playwright test --config=ui-tests/playwright.config.ts",
    "ui:smoke": "npx playwright test --config=ui-tests/playwright.config.ts --grep 'smoke'",
    "ui:report": "npx playwright show-report reports/ui",
    "api:test": "pytest -c api-tests/pytest.ini",
    "api:smoke": "pytest -c api-tests/pytest.ini -m smoke",
    "api:report": "pytest -c api-tests/pytest.ini --html=reports/api-report.html",
    "test": "npm run ui:test && npm run api:test",
    "lint": "npx eslint . --ext .ts",
    "prepare": "npx playwright install --with-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.0",
    "@typescript-eslint/eslint-plugin": "^7.12.1",
    "@typescript-eslint/parser": "^7.12.1",
    "dotenv": "^16.3.1",
    "eslint": "^8.57.0",
    "typescript": "^5.6.0"
  }
}
